  "repository": {
    "type": "git",
    "url": "https://github.com/AIWerk/mcp-server-clawhub.git"
  },
  "homepage": "https://aiwerkmcp.com",
  "bugs": {
    "url": "https://github.com/AIWerk/mcp-server-clawhub/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.1"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
