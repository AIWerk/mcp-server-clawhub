{
  "name": "@aiwerk/mcp-server-clawhub",
  "version": "0.1.2",
  "description": "ClawHub.ai skill catalog MCP server — search, browse, download skills; publish/delete when authenticated",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-server-clawhub": "dist/src/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
